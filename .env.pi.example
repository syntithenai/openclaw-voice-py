# Raspberry Pi profile example for OpenClaw Voice
# Copy to .env.pi and adjust values for your Pi hardware/services.
#
# Runtime selection:
# - auto-selected on ARM hosts
# - can force with OPENCLAW_ENV_FILE=.env.pi

OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace-voice

# Audio devices (use arecord -l / aplay -l)
AUDIO_CAPTURE_DEVICE=hw:2,0
AUDIO_PLAYBACK_DEVICE=hw:2,0
AUDIO_SAMPLE_RATE=16000
AUDIO_PLAYBACK_SAMPLE_RATE=48000
AUDIO_FRAME_MS=20
AUDIO_OUTPUT_GAIN=2.0
AUDIO_PLAYBACK_LEAD_IN_MS=700
AUDIO_PLAYBACK_KEEPALIVE_ENABLED=true
AUDIO_PLAYBACK_KEEPALIVE_INTERVAL_MS=250

# VAD / cut-in
VAD_TYPE=webrtc
VAD_CONFIDENCE=0.6
VAD_MIN_RMS=0.002
VAD_MIN_SILENCE_MS=650
VAD_CUT_IN_RMS=0.008
VAD_CUT_IN_FRAMES=2
VAD_CUT_IN_MIN_MS=100
ALARM_CUT_IN_ARMING_S=0.35
ALARM_CUT_IN_REQUIRED_HITS=2

# Wake word (Pi default: OpenWakeWord; ARMv7 installer policy enforces Precise)
WAKE_WORD_ENABLED=true
WAKE_WORD_TIMEOUT_MS=4000
WAKE_SLEEP_COOLDOWN_MS=3000
WAKE_DETECT_PREBUFFER_MS=280
PRECISE_ENABLED=false
PRECISE_MODEL_PATH=docker/wakeword-models/hey-mycroft.pb
PRECISE_WAKE_WORD=
PRECISE_CONFIDENCE=0.15
OPENWAKEWORD_ENABLED=true
OPENWAKEWORD_MODEL_PATH=hey_mycroft
OPENWAKEWORD_WAKE_WORD=hey_mycroft
OPENWAKEWORD_CONFIDENCE=0.5
PICOVOICE_ENABLED=false

# Chunking
CHUNK_MAX_MS=10000
PRE_ROLL_MS=1500
CUT_IN_PRE_ROLL_MS=100

# Service endpoints (replace with your host IPs)
WHISPER_URL=http://10.1.1.249:10000
PIPER_URL=http://10.1.1.249:10001
PIPER_VOICE_ID=en_US-amy-medium
PIPER_SPEED=1.2
OPENCLAW_GATEWAY_URL=http://10.1.1.249:18789
GATEWAY_AGENT_ID=voice
VOICE_SESSION_PREFIX=main
GATEWAY_DEBOUNCE_MS=1200
GATEWAY_AUTH_TOKEN=

# Pi-friendly defaults
ECHO_CANCEL=false
QUICK_ANSWER_ENABLED=false
QUICK_ANSWER_MODEL_TIER_FAST_ID=
QUICK_ANSWER_MODEL_TIER_BASIC_ID=
QUICK_ANSWER_MODEL_TIER_CAPABLE_ID=
QUICK_ANSWER_MODEL_TIER_SMART_ID=
QUICK_ANSWER_MODEL_TIER_GENIUS_ID=
QUICK_ANSWER_STRICT_ROUTING_ENABLED=false
QUICK_ANSWER_PROCEDURAL_SKILL_ROUTING_ENABLED=false
EMOTION_ENABLED=false
TOOLS_ENABLED=true
TIMERS_ENABLED=true
MUSIC_ENABLED=false
MEDIA_PLAYER_BACKEND=native
MEDIA_LIBRARY_ROOT=music
MEDIA_INDEX_DB_PATH=.media/library.sqlite3
PLAYLIST_ROOT=playlists
MUSIC_COMMAND_TIMEOUT_S=8.0
SNAPCAST_ENABLED=false
SNAPCAST_HOST=localhost
SNAPCAST_PORT=1705

RECORDER_ENABLED=true
RECORDER_OUTPUT_DIR=recordings
RECORDER_PYANNOTE_ENABLED=false
RECORDER_PYANNOTE_URL=http://localhost:10002
RECORDER_PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
RECORDER_PYANNOTE_SERVICE_MODEL=pyannote/speaker-diarization-3.1
RECORDER_STOP_HOTWORD_EXTRA_TRIM_MS=900
RECORDER_STOP_HOTWORD_MAX_TRIM_MS=8000

# Embedded Web UI / WebSocket (optional)
WEB_UI_ENABLED=false
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=18910
WEB_UI_WS_PORT=18911
WEB_UI_STATUS_HZ=12
WEB_UI_HOTWORD_ACTIVE_MS=2000
WEB_UI_SSL_CERTFILE=
WEB_UI_SSL_KEYFILE=
WEB_UI_HTTP_REDIRECT_PORT=0
WEB_UI_STATIC_ROOT=orchestrator/web/static
WEB_UI_AUTH_MODE=disabled
WEB_UI_GOOGLE_CLIENT_SECRET_FILE=../google_client_secret.json
WEB_UI_GOOGLE_CLIENT_ID=
WEB_UI_GOOGLE_CLIENT_SECRET=
WEB_UI_GOOGLE_REDIRECT_URI=
WEB_UI_GOOGLE_ALLOWED_DOMAIN=
WEB_UI_AUTH_SESSION_COOKIE_NAME=openclaw_ui_session
WEB_UI_AUTH_SESSION_TTL_HOURS=24
WEB_UI_AUTH_COOKIE_SECURE=true
WEB_UI_WORKSPACE_FILES_ENABLED=false
WEB_UI_WORKSPACE_FILES_ROOT=
WEB_UI_WORKSPACE_FILES_ALLOW_LISTING=false
WEB_UI_MEDIA_FILES_ENABLED=false
WEB_UI_MEDIA_FILES_ROOT=
WEB_UI_MEDIA_FILES_ALLOW_LISTING=false
