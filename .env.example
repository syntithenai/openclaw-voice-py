# OpenClaw Voice configuration template (commit-safe)
# Copy to one of:
#   .env        -> local/native host runs (default)
#   .env.docker -> local Docker orchestrator runs
#   .env.pi     -> Raspberry Pi runs
#
# Runtime auto-selection order:
# 1) OPENCLAW_ENV_FILE (explicit path)
# 2) .env.docker when running in Docker
# 3) .env.pi on ARM boards
# 4) .env fallback

# ==========================
# Optional env file override
# ==========================
# OPENCLAW_ENV_FILE=.env

# ===== OpenClaw workspace =====
# Shared workspace path for recorder output, timers, and MPD playlists/state.
OPENCLAW_WORKSPACE_DIR=~/.openclaw/workspace-voice

# ===== Audio =====
# AUDIO_CAPTURE_DEVICE / AUDIO_PLAYBACK_DEVICE: default | integer device index | backend device string (e.g. hw:2,0, pipewire)
AUDIO_SAMPLE_RATE=16000
AUDIO_PLAYBACK_SAMPLE_RATE=0
AUDIO_PLAYBACK_LEAD_IN_MS=0
AUDIO_PLAYBACK_KEEPALIVE_ENABLED=false
AUDIO_PLAYBACK_KEEPALIVE_INTERVAL_MS=250
AUDIO_FRAME_MS=20
AUDIO_CAPTURE_DEVICE=default
AUDIO_PLAYBACK_DEVICE=default
# AUDIO_BACKEND: portaudio (recommended)
AUDIO_BACKEND=portaudio
AUDIO_INPUT_GAIN=1.0
AUDIO_OUTPUT_GAIN=1.0
TTS_RELATIVE_GAIN=0.75

# ===== VAD =====
# VAD_TYPE: webrtc | silero | none
VAD_TYPE=webrtc
VAD_CONFIDENCE=0.5
VAD_MIN_SPEECH_MS=50
VAD_MIN_SILENCE_MS=800
VAD_MIN_RMS=0.002
VAD_CUT_IN_RMS=0.0025
VAD_CUT_IN_MIN_MS=150
VAD_CUT_IN_FRAMES=3
VAD_CUT_IN_TTS_HOLD_TIMEOUT_MS=4500
VAD_CUT_IN_USE_SILERO=false
VAD_CUT_IN_SILERO_CONFIDENCE=0.3
SILERO_MODEL_PATH=
SILERO_AUTO_DOWNLOAD=true
SILERO_MODEL_URL=https://raw.githubusercontent.com/snakers4/silero-vad/v5.1.2/src/silero_vad/data/silero_vad.onnx
SILERO_MODEL_CACHE_DIR=docker/silero-models

# ===== Wakeword resources =====
OPENWAKEWORD_MODELS_DIR=docker/wakeword-models
OPENWAKEWORD_AUTO_DOWNLOAD=true
EMOTION_MODELS_DIR=docker/emotion-models
EMOTION_AUTO_DOWNLOAD=true

# ===== AEC =====
ECHO_CANCEL=true
# ECHO_CANCEL_STRENGTH: low | medium | strong
ECHO_CANCEL_STRENGTH=strong

# ===== Wake word global =====
WAKE_WORD_ENABLED=false
WAKE_WORD_TIMEOUT_MS=4000
WAKE_SLEEP_COOLDOWN_MS=2500
WAKE_MIN_DETECT_RMS=0.0015
WAKE_CLEAR_RING_BUFFER=false
WAKE_DETECT_PREBUFFER_MS=280

# ===== Wake word: Precise (ARM/Pi friendly) =====
PRECISE_ENABLED=false
PRECISE_WAKE_WORD=hey-mycroft
PRECISE_MODEL_PATH=docker/wakeword-models/hey-mycroft.pb
PRECISE_CONFIDENCE=0.15

# ===== Wake word: OpenWakeWord =====
OPENWAKEWORD_ENABLED=true
OPENWAKEWORD_WAKE_WORD=hey_mycroft
OPENWAKEWORD_MODEL_PATH=hey_mycroft
OPENWAKEWORD_CONFIDENCE=0.5

# ===== Wake word: Picovoice =====
PICOVOICE_ENABLED=false
PICOVOICE_WAKE_WORD=
PICOVOICE_KEY=
PICOVOICE_CONFIDENCE=0.5

# ===== Chunking =====
CHUNK_MAX_MS=10000
PRE_ROLL_MS=2000
CUT_IN_PRE_ROLL_MS=100

# ===== Services =====
WHISPER_URL=http://localhost:10000
PIPER_URL=http://localhost:10001
PIPER_VOICE_ID=en_US-amy-medium
PIPER_SPEED=1.0

# ===== Gateway =====
# GATEWAY_PROVIDER / VOICE_CLAW_PROVIDER: openclaw | generic | zeroclaw | tinyclaw | ironclaw | mimiclaw | picoclaw | nanobot
GATEWAY_PROVIDER=openclaw
GATEWAY_WS_URL=
GATEWAY_HTTP_URL=
GATEWAY_HTTP_ENDPOINT=/api/short
GATEWAY_AGENT_ID=voice
GATEWAY_AUTH_TOKEN=
OPENCLAW_GATEWAY_URL=http://localhost:18789
GATEWAY_TIMEOUT_MS=30000
VOICE_SESSION_PREFIX=voice
GATEWAY_DEBOUNCE_MS=2000
GATEWAY_TTS_FAST_START_WORDS=5

# ===== ZeroClaw =====
ZEROCLAW_GATEWAY_URL=http://localhost:3000
ZEROCLAW_WEBHOOK_TOKEN=
ZEROCLAW_CHANNEL=voice

# ===== TinyClaw =====
TINYCLAW_HOME=
TINYCLAW_AGENT_ID=

# ===== IronClaw =====
IRONCLAW_GATEWAY_URL=http://localhost:8888
IRONCLAW_GATEWAY_TOKEN=
IRONCLAW_USE_WEBSOCKET=true
IRONCLAW_AGENT_ID=

# ===== MimiClaw =====
MIMICLAW_DEVICE_HOST=localhost
MIMICLAW_DEVICE_PORT=18789
MIMICLAW_USE_WEBSOCKET=true
MIMICLAW_TELEGRAM_BOT_TOKEN=
MIMICLAW_TELEGRAM_CHAT_ID=

# ===== PicoClaw =====
PICOCLAW_HOME=
PICOCLAW_GATEWAY_URL=
PICOCLAW_AGENT_ID=

# ===== NanoBot =====
NANOBOT_HOME=
NANOBOT_GATEWAY_URL=http://localhost:18790
NANOBOT_AGENT_ID=

# ===== Emotion =====
EMOTION_ENABLED=false
# EMOTION_MODEL: sensevoice-small (default)
EMOTION_MODEL=sensevoice-small
EMOTION_TIMEOUT_MS=300
SENSEVOICE_MODEL_PATH=

# ===== Quick Answer =====
QUICK_ANSWER_ENABLED=false
QUICK_ANSWER_LLM_URL=
# QUICK_ANSWER_MODEL examples: gpt-4o-mini, ibm/granite-4-h-tiny, local model IDs
QUICK_ANSWER_MODEL=
QUICK_ANSWER_API_KEY=
QUICK_ANSWER_TIMEOUT_MS=5000
QUICK_ANSWER_MIRROR_ENABLED=false
QUICK_ANSWER_BYPASS_WINDOW_MS=8000

# ===== STT ghost transcript suppression =====
GHOST_FILTER_ENABLED=true
GHOST_FILTER_SINGLE_WORD_ENABLED=true
GHOST_FILTER_REQUIRE_QUESTION_FOR_ACKS=true
GHOST_FILTER_PLAYBACK_TAIL_MS=1200
GHOST_FILTER_CUTIN_EARLY_MS=500
GHOST_FILTER_RECENT_ASSISTANT_MS=12000
GHOST_FILTER_UPSTREAM_CONTEXT_MS=20000
GHOST_FILTER_SELF_ECHO_SIMILARITY_THRESHOLD=0.75
GHOST_FILTER_DEBUG_LOGGING=true
GHOST_FILTER_KILL_SWITCH=false

# ===== Recorder Tool =====
RECORDER_ENABLED=true
RECORDER_OUTPUT_DIR=recordings
RECORDER_PYANNOTE_ENABLED=false
# Required for gated Hugging Face model IDs (e.g. pyannote/speaker-diarization-3.1).
# Not required if RECORDER_PYANNOTE_MODEL points to a local model path snapshot.
RECORDER_PYANNOTE_AUTH_TOKEN=
RECORDER_PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
RECORDER_PYANNOTE_URL=http://localhost:10002
PYANNOTE_BACKEND_PREFERENCE=auto
PYANNOTE_CPU_FALLBACK=true

# ===== Embedded Web UI / WebSocket (continuous browser audio mode) =====
WEB_UI_ENABLED=false
WEB_UI_HOST=0.0.0.0
WEB_UI_PORT=18910
WEB_UI_WS_PORT=18911
WEB_UI_STATUS_HZ=12
WEB_UI_HOTWORD_ACTIVE_MS=2000
WEB_UI_SSL_CERTFILE=
WEB_UI_SSL_KEYFILE=
WEB_UI_HTTP_REDIRECT_PORT=0

# ===== Tools / timers =====
TOOLS_ENABLED=true
TIMERS_ENABLED=true
TOOLS_PERSIST_DIR=timers
TOOLS_DEBOUNCE_MS=75
TOOLS_MONITOR_INTERVAL_MS=100
TOOLS_CLEAR_ON_STARTUP=true

# ===== Music / MPD =====
MUSIC_ENABLED=false
MPD_HOST=localhost
MPD_PORT=6600
MPD_TIMEOUT=5.0
MPD_POOL_SIZE=3
MPD_PLAYLIST_DIR=playlists
MPD_STATE_DIR=.mpd
MUSIC_FAST_PATH_ENABLED=true
MUSIC_SLEEP_DURING_PLAYBACK=true
MUSIC_AUTO_RESUME_TIMEOUT_S=5
MUSIC_RANDOM_TRACK_COUNT=50
MUSIC_GENRE_QUEUE_LIMIT=120
MUSIC_TTS_DUCK_ENABLED=true
MUSIC_TTS_DUCK_RATIO=0.45
MUSIC_CUT_IN_DUCK_RATIO=0.35
MUSIC_CUT_IN_DUCK_TIMEOUT_MS=2000

# ===== Media keys =====
MEDIA_KEYS_ENABLED=false
MEDIA_KEYS_DEVICE_FILTER=
MEDIA_KEYS_EXCLUSIVE_GRAB=false
MEDIA_KEYS_CONTROL_MUSIC=false
MEDIA_KEYS_SUPPRESS_SYSTEM_PLAY=true
MEDIA_KEYS_PASSTHROUGH_KEYS=volume_up,volume_down,mute
MEDIA_KEYS_PLAY_SCAN_CODES=0xc00b6,0xc00cd
MEDIA_KEYS_VOLUME_UP_SCAN_CODES=0xc00e9
MEDIA_KEYS_VOLUME_DOWN_SCAN_CODES=0xc00ea
MEDIA_KEYS_COMMAND_DEBOUNCE_MS=400

# ===== Wake/Sleep feedback sounds =====
# WAKE_FEEDBACK_VARIANT: click|double|bright|soft|cluck|doublecluck|knock|knocklow|doubleknock
WAKE_FEEDBACK_VARIANT=click
# SLEEP_FEEDBACK_VARIANT: swoosh|short|deep|sigh|sighshort|exhale|exhaleshort|exhalelong|none
SLEEP_FEEDBACK_VARIANT=swoosh
WAKE_FEEDBACK_GAIN=1.6
SLEEP_FEEDBACK_GAIN=1.3
VOLUME_FEEDBACK_GAIN=0.4
