# Docker profile example for OpenClaw Voice
# Copy to .env.docker and adjust values.
#
# Runtime selection:
# - auto-selected in container
# - can force with OPENCLAW_ENV_FILE=.env.docker

OPENCLAW_WORKSPACE_DIR=/app/workspace

# Audio device indices for containerized PortAudio
AUDIO_CAPTURE_DEVICE=0
AUDIO_PLAYBACK_DEVICE=0
AUDIO_BACKEND=portaudio

# Compose internal endpoints
WHISPER_URL=http://whisper:10000
PIPER_URL=http://piper:10001
RECORDER_PYANNOTE_URL=http://pyannote:10002
WHISPER_BACKEND_PREFERENCE=auto
WHISPER_CPU_FALLBACK=true
PIPER_BACKEND_PREFERENCE=auto
PIPER_CPU_FALLBACK=true
PYANNOTE_BACKEND_PREFERENCE=auto
PYANNOTE_CPU_FALLBACK=true
MPD_HOST=127.0.0.1
MPD_PORT=6600
MPD_PLAYLIST_DIR=playlists
MPD_STATE_DIR=.mpd
MPD_FIFO_HOST_PATH=/tmp/openclaw-mpd-fifo
MPD_FIFO_ENABLED=true
MPD_FIFO_PATH=/tmp/mpd-fifo/music.pcm
MPD_FIFO_SAMPLE_RATE=44100
MPD_FIFO_CHANNELS=2
MPD_FIFO_BITS_PER_SAMPLE=16
MPD_FIFO_CHUNK_BYTES=16384
MPD_MIX_GAIN=1.0
MPD_MIX_DUCK_TTS_GAIN=0.30
MPD_MIX_DUCK_ALARM_GAIN=0.12
MPD_MIX_DUCK_LISTENING_GAIN=0.25
SNAPCAST_ENABLED=false
SNAPCAST_HOST=snapserver
SNAPCAST_PORT=1705

# Container model/cache paths
SILERO_MODEL_CACHE_DIR=/app/docker/silero-models
OPENWAKEWORD_MODELS_DIR=/app/docker/wakeword-models
EMOTION_MODELS_DIR=/app/docker/emotion-models
MODELSCOPE_CACHE=/app/.cache/modelscope

# Gateway from inside container
OPENCLAW_GATEWAY_URL=http://host.docker.internal:18789
VOICE_CLAW_PROVIDER=openclaw
GATEWAY_AGENT_ID=voice
VOICE_SESSION_PREFIX=voice
GATEWAY_DEBOUNCE_MS=1200
GATEWAY_AUTH_TOKEN=

# Wake-word defaults (x86/amd64-friendly)
WAKE_WORD_ENABLED=true
PRECISE_ENABLED=false
OPENWAKEWORD_ENABLED=true
OPENWAKEWORD_MODEL_PATH=hey_mycroft
OPENWAKEWORD_WAKE_WORD=hey_mycroft
WAKE_DETECT_PREBUFFER_MS=280
OPENWAKEWORD_CONFIDENCE=0.5
PICOVOICE_ENABLED=false

# Optional features
QUICK_ANSWER_ENABLED=false
EMOTION_ENABLED=false
TOOLS_ENABLED=true
TIMERS_ENABLED=true
MUSIC_ENABLED=true
RECORDER_ENABLED=true
RECORDER_OUTPUT_DIR=recordings
RECORDER_PYANNOTE_ENABLED=false
RECORDER_PYANNOTE_AUTH_TOKEN=
RECORDER_PYANNOTE_MODEL=pyannote/speaker-diarization-3.1
